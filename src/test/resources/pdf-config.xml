<configuration>

    <!-- Theme -->
    <theme>standard</theme>

    <!-- Titles -->
    <documentTitle>Factorial Automation Report</documentTitle>
    <reportName>Test Execution Results</reportName>
    <title>Factorial Application - Automation and API Test Report</title>

    <!-- Primary Colors (Clean Blue Theme) -->
    <titleColor>1E88E5</titleColor>

    <!-- Timing Colors (Neutral) -->
    <startTimesColor>757575</startTimesColor>
    <finishTimesColor>757575</finishTimesColor>
    <durationColor>546E7A</durationColor>

    <!-- Status Counts -->
    <passCountColor>2E7D32</passCountColor>

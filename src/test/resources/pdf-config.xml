    <!-- Status Colors -->
    <passColor>2E7D32</passColor>      <!-- Green -->
    <failColor>C62828</failColor>      <!-- Red -->
    <skipColor>F9A825</skipColor>      <!-- Amber -->
    <warnColor>F57C00</warnColor>
